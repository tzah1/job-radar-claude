# Job Radar — Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit .env to git.

# Optional: request headers for scraping (not required for v1)
# JOB_RADAR_USER_AGENT=Mozilla/5.0 (compatible; JobRadar/1.0)

# Optional: Telegram bot token (for future Telegram integration)
# See docs/telegram_integration_plan.md before enabling
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Optional: Google Sheets (for future integration)
# See docs/google_sheets_future_integration.md before enabling
# GOOGLE_CREDENTIALS_PATH=
# GOOGLE_SHEET_ID=

# Optional: override default paths
# JOB_RADAR_BASE_DIR=
